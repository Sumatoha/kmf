# Server
APP_ENV=dev
HTTP_ADDR=:8080

# Database (local Postgres via docker-compose; replace with Supabase URL later)
DATABASE_URL=postgres://cleanops:cleanops_dev@localhost:5432/cleanops?sslmode=disable

# Auth
JWT_SECRET=change-me-in-prod-please-use-32-bytes-min
JWT_TTL=168h

# CORS — comma-separated origins. Empty/unset = "*" (dev only!)
CORS_ORIGINS=http://localhost:3000

# Telegram bots (get tokens from @BotFather; leave empty to disable a bot)
TELEGRAM_CLIENT_BOT_TOKEN=
TELEGRAM_MASTER_BOT_TOKEN=

# Public bot usernames (without @) — used to build deep links
TELEGRAM_CLIENT_BOT_USERNAME=CleanOpsBookingBot
TELEGRAM_MASTER_BOT_USERNAME=CleanOpsMasterBot

# Bot session retention — older idle sessions are pruned hourly
BOT_SESSION_RETENTION=720h

# Logging: debug | info | warn | error
LOG_LEVEL=info

# --- Frontend (Next.js) ----------------------------------------------------
# Backend URL the Next.js dev server proxies /api/* to.
BACKEND_URL=http://localhost:8080
# Master bot username used by the CRM to render invite links.
NEXT_PUBLIC_MASTER_BOT_USERNAME=CleanOpsMasterBot
